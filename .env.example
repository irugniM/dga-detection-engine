# --- TELEGRAM ALERTS CONFIGURATION ---
# Set up a new bot on Telegram via @BotFather to receive your API Token
TELEGRAM_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# Use @userinfobot or send a message to your bot and query: https://api.telegram.org/bot<TOKEN>/getUpdates to find your Chat ID
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# --- MODEL PATH OVERRIDES ---
# By default, agent.py automatically loads models/dga_lstm_model.tflite if it exists.
# You can uncomment and override the model or vocabulary paths below if needed:
# MODEL_PATH=models/dga_lstm_model.tflite
# VOCAB_PATH=models/char_index.json
